<Window x:Class="HangmanClient.CreateMatch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/Properties/Images/Match.png" Grid.ColumnSpan="2" Stretch="UniformToFill" Opacity="0.5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <Label Content="ID: " Style="{StaticResource lblSubtitulo}" FontSize="24"/>
            <Label Content="0000" Style="{StaticResource lblSubtitulo}" FontSize="24" Foreground="Maroon"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,40,0">
            <Button x:Name="btnLeave" Content="Salir" 
                    Style="{StaticResource btnMain}" 
                    Width="160" Height="50" Margin="0,0,20,0" Background="#A0522D" FontSize="18" Click="btnLeave_Click"/>
            <Button x:Name="btnStart"  Content="Comenzar" 
                    Style="{StaticResource btnMain}" 
                    Width="160" Height="50" FontSize="18" Click="btnStart_Click"/>
        </StackPanel>

        <Label Content="ESPERANDO RIVAL..." 
               Style="{StaticResource lblTitulo}" 
               FontSize="80" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               Margin="0,0,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,40">

            <Label Content="CATEGORÍA:" Style="{StaticResource lblSubtitulo}" VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbCategory" Style="{StaticResource cmbNormal}" Margin="10,0,40,0" SelectionChanged="cmbCategory_SelectionChanged">
                <ComboBoxItem Content=""/>
                <ComboBoxItem Content=""/>
            </ComboBox>

            <Label Content="PALABRA:" Style="{StaticResource lblSubtitulo}" VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbWord" Style="{StaticResource cmbNormal}" Margin="10,0,0,0" SelectionChanged="cmbWord_SelectionChanged">
                <ComboBoxItem Content="Caballo"/>
                <ComboBoxItem Content="Elefante"/>
            </ComboBox>

        </StackPanel>

    </Grid>
</Window>
