<Window x:Class="HangmanClient.CreateMatch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid>
        <Image Source="/Properties/Images/Match.png" Grid.ColumnSpan="2" Stretch="UniformToFill" Opacity="0.5"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <Label Content="ID: " Style="{StaticResource lblSubtitle}" FontSize="24"/>
            <Label x:Name="lblMatchIdDisplay" Content="" Style="{StaticResource lblSubtitle}" FontSize="24" Foreground="Maroon"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,40,0">
            <Button x:Name="btnLeave" Content="{x:Static p:Resources.lbLeave}" 
                    Style="{StaticResource btnMain}" 
                    Width="160" Height="50" Margin="0,0,20,0" Background="#A0522D" FontSize="18" Click="btnLeave_Click"/>
            <Button x:Name="btnStart"  Content="{x:Static p:Resources.btnStart}" 
                    Style="{StaticResource btnMain}" 
                    Width="160" Height="50" FontSize="18" Click="btnStart_Click"/>
        </StackPanel>

        <Label x:Name="lbWaitingOpponent" Content="{x:Static p:Resources.lbWaitingOpponent}" 
               Style="{StaticResource lblTitle}" 
               FontSize="80" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               Margin="0,0,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,40">

            <Label Content="{x:Static p:Resources.lbCategory}" Style="{StaticResource lblSubtitle}" VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbCategory" Style="{StaticResource cmbNormal}" Margin="10,0,40,0" SelectionChanged="cmbCategory_SelectionChanged"/>

            <Label Content="{x:Static p:Resources.lbWord}" Style="{StaticResource lblSubtitle}" VerticalAlignment="Center"/>

            <ComboBox x:Name="cmbWord" Style="{StaticResource cmbNormal}" Margin="10,0,0,0" SelectionChanged="cmbWord_SelectionChanged"/>

        </StackPanel>

    </Grid>
</Window>