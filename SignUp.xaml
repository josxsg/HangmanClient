<Window x:Class="HangmanClient.SignUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="CanResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/Properties/Images/Login.png" Grid.ColumnSpan="2" Stretch="UniformToFill"/>

        <Button x:Name="btnBack" Content="◄-" 
                Style="{StaticResource btnMain}" 
                HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="30,30,0,0" 
                Height="45" FontSize="18"
                Padding="20,0,20,0"
                Grid.Column="0"
                Click="btnBack_Click"/>

        <Border Grid.Column="1" Padding="40,20">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <Label Content="{x:Static p:Resources.lbSignUp}" 
                       Style="{StaticResource lblTitle}" Margin="0,0,0,10"/>

                <Label Content="{x:Static p:Resources.lbName}" Style="{StaticResource lblSubtitle}"/>
                <TextBox x:Name="txtName" Style="{StaticResource txtNormal}" Width="350" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label Content="{x:Static p:Resources.lbLastName}" Style="{StaticResource lblSubtitle}" FontSize="15"/>
                        <TextBox x:Name="txtSecondName" Style="{StaticResource txtNormal}" Width="170"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label Content="{x:Static p:Resources.lbLastName_Mother_}" Style="{StaticResource lblSubtitle}" FontSize="15"/>
                        <TextBox x:Name="txtApellidoMaterno" Style="{StaticResource txtNormal}" Width="170"/>
                    </StackPanel>
                </Grid>

                <Label Content="{x:Static p:Resources.lbDateOfBirth}" Style="{StaticResource lblSubtitle}"/>
                <DatePicker x:Name="dpFechaNacimiento" Style="{StaticResource dpNormal}" Margin="0,0,0,15"/>

                <Label Content="{x:Static p:Resources.lbUsername}" Style="{StaticResource lblSubtitle}"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource txtNormal}" Width="350" Margin="0,0,0,15"/>

                <Label Content="{x:Static p:Resources.lbEmail}" Style="{StaticResource lblSubtitle}"/>
                <TextBox x:Name="txtBoxEmail" Style="{StaticResource txtNormal}" Width="350" Margin="0,0,0,15" />

                <Label Content="{x:Static p:Resources.lbPhone}" Style="{StaticResource lblSubtitle}"/>
                <TextBox x:Name="txtPhone" Style="{StaticResource txtNormal}" Width="350" Margin="0,0,0,15" />

                <Label Content="{x:Static p:Resources.lblPassword}" Style="{StaticResource lblSubtitle}"/>
                <PasswordBox x:Name="pswBoxPassword" Style="{StaticResource pwdNormal}" Width="350" Margin="0,0,0,25"/>

                <Button x:Name="btnSignUp" Content="{x:Static p:Resources.btnRegister}" 
                        Style="{StaticResource btnMain}"
                        Width="280" Height="60" Click="btnSignUp_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>