<Window x:Class="HangmanClient.Match"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="CanResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/Properties/Images/Game.png" Grid.ColumnSpan="2" Stretch="UniformToFill"/>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="ID PARTIDA: " Style="{StaticResource lblSubtitulo}"/>
                <Label x:Name="lbMatchId" Content="0000" Style="{StaticResource lblSubtitulo}" Foreground="Maroon"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Label Content="CATEGORÍA: " Style="{StaticResource lblSubtitulo}"/>
                <Label x:Name="lbCategory" Content="ANIMALES" Style="{StaticResource lblSubtitulo}" Foreground="Maroon"/>
            </StackPanel>
        </StackPanel>

        <Button x:Name="btnLeave" Content="ABANDONAR" 
                Style="{StaticResource btnMain}" 
                Width="200" Height="50" FontSize="18" Background="#A0522D"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,40,0" Click="btnLeave_Click"/>

        <Button x:Name="btnChat" Content="" 
                Style="{StaticResource btnCuadrado}" 
                ToolTip="Chat de Partida"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40" Click="btnChat_Click"/>

        <Popup x:Name="popChat" PlacementTarget="{Binding ElementName=btnChat}" 
               Placement="Left"
               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">

            <Border Style="{StaticResource bdrCuadroTexto}" Width="350" Height="450" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="CHAT DE PARTIDA" Style="{StaticResource lblTitulo}" FontSize="22" Margin="0,0,0,10"/>
                    <Border Grid.Row="0" Height="2" Background="#8B4513" VerticalAlignment="Bottom" Margin="0,0,0,5"/>

                    <ScrollViewer x:Name="scrollChat" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5,0,10">
                        <ItemsControl x:Name="itemsChat">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <StackPanel Margin="0,5,0,10">
                                        <TextBlock Text="{Binding NombreJugador}" Foreground="{Binding ColorNombre}" 
                                                   FontFamily="Courier New" FontWeight="Bold" FontSize="16"/>

                                        <TextBlock Text="{Binding TextoMensaje}" Style="{StaticResource txtCuadro}" 
                                                   FontSize="16" Margin="10,2,0,0"/>
                                    </StackPanel>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtMensajeChat" Grid.Column="0" Style="{StaticResource txtNormal}" 
                                 Width="Auto" Height="40" FontSize="16"/>

                        <Button x:Name="btnEnviarMensaje" Grid.Column="1" Content="➤" 
                                Style="{StaticResource btnCuadrado}" 
                                Width="40" Height="40" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Popup>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,325,0,0" Width="320">

            <Border Style="{StaticResource bdrCuadroTexto}" Height="auto">
                <TextBlock x:Name="txtDescription" 
                           Style="{StaticResource txtCuadro}" TextWrapping="Wrap"
                           Text="Aquí aparecerán los mensajes del juego, pistas o notificaciones..."/>
            </Border>

            <Border x:Name="bdrCreatorGuide" Style="{StaticResource bdrCuadroTexto}" Margin="0,15,0,0" Visibility="Collapsed">
                <StackPanel Margin="5">
                    <TextBlock Text="PALABRA SECRETA (GUÍA):" Foreground="Maroon" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <ItemsControl x:Name="icSecretWordGuide" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Letter}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Position}" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,100,0,0">

            <Grid Width="250" Height="350">

                <Image x:Name="imgCabeza" Source="/Properties/Images/Cabeza.png" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="125,-30,0,0" Width="80" Visibility="Visible"/>

                <Image x:Name="imgCuerpo" Source="/Properties/Images/Cuerpo.png" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="125,45,0,0" Width="80" Visibility="Hidden"/>

                <Image x:Name="imgBrazoIzq" Source="/Properties/Images/BrazoIzq.png" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="80,50,0,0" Width="45" Visibility="Hidden"/>

                <Image x:Name="imgBrazoDer" Source="/Properties/Images/BrazoDer.png" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="205,50,0,0" Width="45" Visibility="Hidden"/>

                <Image x:Name="imgPiernaIzq" Source="/Properties/Images/PiernaIzq.png" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="100,150,0,0" Width="40" Visibility="Hidden"/>

                <Image x:Name="imgPiernaDer" Source="/Properties/Images/PiernaDer.png" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" 
                       Margin="165,150,0,0" Width="40" Visibility="Hidden"/>

            </Grid>

            <TextBlock x:Name="txtPalabraOculta" 
                       Text="_ _ _ _ _ _ _ _" 
                       Style="{StaticResource txtCuadro}" 
                       FontSize="60" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,0"/>

        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button x:Name="btnQ" Content="Q" Style="{StaticResource btnLetra}" Click="btnQ_Click"/>
                <Button x:Name="btnW" Content="W" Style="{StaticResource btnLetra}" Click="btnW_Click"/>
                <Button x:Name="btnE" Content="E" Style="{StaticResource btnLetra}" Click="btnE_Click"/>
                <Button x:Name="btnR" Content="R" Style="{StaticResource btnLetra}" Click="btnR_Click"/>
                <Button x:Name="btnT" Content="T" Style="{StaticResource btnLetra}" Click="btnT_Click"/>
                <Button x:Name="btnY" Content="Y" Style="{StaticResource btnLetra}" Click="btnY_Click"/>
                <Button x:Name="btnU" Content="U" Style="{StaticResource btnLetra}" Click="btnU_Click"/>
                <Button x:Name="btnI" Content="I" Style="{StaticResource btnLetra}" Click="btnI_Click"/>
                <Button x:Name="btnO" Content="O" Style="{StaticResource btnLetra}" Click="btnO_Click"/>
                <Button x:Name="btnP" Content="P" Style="{StaticResource btnLetra}" Click="btnP_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button x:Name="btnA" Content="A" Style="{StaticResource btnLetra}" Click="btnA_Click"/>
                <Button x:Name="btnS" Content="S" Style="{StaticResource btnLetra}" Click="btnS_Click"/>
                <Button x:Name="btnD" Content="D" Style="{StaticResource btnLetra}" Click="btnD_Click"/>
                <Button x:Name="btnF" Content="F" Style="{StaticResource btnLetra}" Click="btnF_Click"/>
                <Button x:Name="btnG" Content="G" Style="{StaticResource btnLetra}" Click="btnG_Click"/>
                <Button x:Name="btnH" Content="H" Style="{StaticResource btnLetra}" Click="btnH_Click"/>
                <Button x:Name="btnJ" Content="J" Style="{StaticResource btnLetra}" Click="btnJ_Click"/>
                <Button x:Name="btnK" Content="K" Style="{StaticResource btnLetra}" Click="btnK_Click"/>
                <Button x:Name="btnL" Content="L" Style="{StaticResource btnLetra}" Click="btnL_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnZ" Content="Z" Style="{StaticResource btnLetra}" Click="btnZ_Click"/>
                <Button x:Name="btnX" Content="X" Style="{StaticResource btnLetra}" Click="btnX_Click"/>
                <Button x:Name="btnC" Content="C" Style="{StaticResource btnLetra}" Click="btnC_Click"/>
                <Button x:Name="btnV" Content="V" Style="{StaticResource btnLetra}" Click="btnV_Click"/>
                <Button x:Name="btnB" Content="B" Style="{StaticResource btnLetra}" Click="btnB_Click"/>
                <Button x:Name="btnN" Content="N" Style="{StaticResource btnLetra}" Click="btnN_Click"/>
                <Button x:Name="btnM" Content="M" Style="{StaticResource btnLetra}" Click="btnM_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>