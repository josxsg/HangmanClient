<Window x:Class="HangmanClient.Match"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Grid>

        <Image x:Name="imgBackground" Source="/Properties/Images/Game.png" Grid.ColumnSpan="2" Stretch="UniformToFill"/>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="{x:Static p:Resources.lbMatchId}" Style="{StaticResource lblSubtitle}"/>
                <Label x:Name="lbMatchId" Content="0000" Style="{StaticResource lblSubtitle}" Foreground="Maroon"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Label Content="{x:Static p:Resources.lbCategory}" Style="{StaticResource lblSubtitle}"/>
                <Label x:Name="lbCategory" Content="ANIMALES" Style="{StaticResource lblSubtitle}" Foreground="Maroon"/>
            </StackPanel>

            <StackPanel Width="320" HorizontalAlignment="Left" Margin="0,0,0,20">
                <Border x:Name="bdrCreatorGuide" Style="{StaticResource bdrSquareText}" Margin="0,0,0,15" Visibility="Collapsed">
                    <StackPanel Margin="5">
                        <TextBlock Text="" Foreground="Maroon" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <ItemsControl x:Name="icSecretWordGuide" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{Binding Letter}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Position}" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource bdrSquareText}" Height="auto">
                    <TextBlock x:Name="txtDescription" Style="{StaticResource txtBlock}" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </StackPanel>

        <Button x:Name="btnLeave" Content="{x:Static p:Resources.lbLeave}" 
                Style="{StaticResource btnMain}" 
                Width="200" Height="50" FontSize="18" Background="#A0522D"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,40,0" Click="btnLeave_Click"/>

        <Button x:Name="btnChat" 
                Style="{StaticResource btnSquare}" 
                ToolTip="{x:Static p:Resources.lbChat}"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40" 
                Click="btnChat_Click">
            <Image Source="/Properties/Images/chat.png" Width="30" Height="30" Stretch="Uniform"/>
        </Button>

        <Popup x:Name="popChat" PlacementTarget="{Binding ElementName=btnChat}" 
               Placement="Left" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
            <Border Style="{StaticResource bdrSquareText}" Width="350" Height="450" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="{x:Static p:Resources.lbLiveChat}" Style="{StaticResource lblTitle}" FontSize="22" Margin="0,0,0,10"/>
                    <Border Grid.Row="0" Height="2" Background="#8B4513" VerticalAlignment="Bottom" Margin="0,0,0,5"/>

                    <ScrollViewer x:Name="scrollChat" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5,0,10">
                        <ItemsControl x:Name="itemsChat">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,5,0,10" TextWrapping="Wrap" Style="{StaticResource txtBlock}" FontSize="16">
                                        <Run Text="{Binding PlayerName}" Foreground="{Binding NameColor}" FontFamily="Courier New" FontWeight="Bold"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding MessageText}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtMensajeChat" Grid.Column="0" Style="{StaticResource txtNormal}" 
                                 Width="Auto" Height="40" FontSize="16" MaxLength="250"/>

                        <Button x:Name="btnEnviarMensaje" Grid.Column="1" Content="➤" 
                                Style="{StaticResource btnSquare}" 
                                Width="40" Height="40" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Popup>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,30">

            <ItemsControl x:Name="icPalabraOculta" HorizontalAlignment="Center" Margin="0,0,0,15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Letter}" 
                                Tag="{Binding Index}"
                                FontSize="35" 
                                FontWeight="Bold"
                                Width="45" Height="55"
                                Margin="4,0,4,0"
                                Background="Transparent"
                                BorderBrush="DarkGray"
                                BorderThickness="0,0,0,3"
                                Foreground="#333333"
                                IsEnabled="{Binding IsEditing}"
                                Cursor="Hand"
                                Click="WordSlot_Click"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="btnConfirmPositions" 
                    Content="{x:Static p:Resources.btnChoosePos}" 
                    Style="{StaticResource btnMain}" 
                    Height="40" Padding="20,0" Margin="0,0,0,20"
                    Visibility="Collapsed" 
                    Background="#2E8B57"
                    HorizontalAlignment="Center"
                    Click="btnConfirmPositions_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button x:Name="btnQ" Content="Q" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnQ_Click"/>
                <Button x:Name="btnW" Content="W" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnW_Click"/>
                <Button x:Name="btnE" Content="E" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnE_Click"/>
                <Button x:Name="btnR" Content="R" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnR_Click"/>
                <Button x:Name="btnT" Content="T" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnT_Click"/>
                <Button x:Name="btnY" Content="Y" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnY_Click"/>
                <Button x:Name="btnU" Content="U" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnU_Click"/>
                <Button x:Name="btnI" Content="I" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnI_Click"/>
                <Button x:Name="btnO" Content="O" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnO_Click"/>
                <Button x:Name="btnP" Content="P" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnP_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button x:Name="btnA" Content="A" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnA_Click"/>
                <Button x:Name="btnS" Content="S" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnS_Click"/>
                <Button x:Name="btnD" Content="D" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnD_Click"/>
                <Button x:Name="btnF" Content="F" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnF_Click"/>
                <Button x:Name="btnG" Content="G" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnG_Click"/>
                <Button x:Name="btnH" Content="H" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnH_Click"/>
                <Button x:Name="btnJ" Content="J" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnJ_Click"/>
                <Button x:Name="btnK" Content="K" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnK_Click"/>
                <Button x:Name="btnL" Content="L" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnL_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnZ" Content="Z" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnZ_Click"/>
                <Button x:Name="btnX" Content="X" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnX_Click"/>
                <Button x:Name="btnC" Content="C" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnC_Click"/>
                <Button x:Name="btnV" Content="V" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnV_Click"/>
                <Button x:Name="btnB" Content="B" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnB_Click"/>
                <Button x:Name="btnN" Content="N" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnN_Click"/>
                <Button x:Name="btnM" Content="M" Style="{StaticResource btnLetter}" Width="50" Height="55" FontSize="24" Margin="3" Click="btnM_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>