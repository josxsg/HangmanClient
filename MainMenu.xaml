<Window x:Class="HangmanClient.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="CanResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/Properties/Images/Menu.png" Grid.ColumnSpan="2" Stretch="UniformToFill" Opacity="0.5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <Label Content="{x:Static p:Resources.lbWelcome}" Style="{StaticResource lblSubtitle}" FontSize="24"/>
            <Label x:Name="lbUsername" Content="" Style="{StaticResource lblSubtitle}" FontSize="24" Foreground="Maroon"/>
        </StackPanel>

        <Button x:Name="btnMyPoints" 
        Style="{StaticResource btnSquare}" 
        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,40,0"
        ToolTip="{x:Static p:Resources.ttMyPoints}" Click="btnMyPoints_Click">

            <Image Source="/Properties/Images/myPoints.png" Width="30" Height="30" Stretch="Uniform"/>

        </Button>
        <Popup x:Name="popMyPoints" PlacementTarget="{Binding ElementName=btnMyPoints}" 
               Placement="Left" 
               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">

            <Border Style="{StaticResource bdrSquareText}" Width="400" MaxHeight="500" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="{x:Static p:Resources.ttMyPoints}" Style="{StaticResource lblTitle}" FontSize="28" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="{x:Static p:Resources.lbMatches}" Style="{StaticResource lblSubtitle}" FontSize="18" HorizontalAlignment="Left"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Label Content="{x:Static p:Resources.lbTotal}" Style="{StaticResource lblSubtitle}" FontSize="18"/>
                            <Label x:Name="lblTotalPoints" Content="0 pts" Style="{StaticResource lblSubtitle}" FontSize="18" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Height="3" Background="#8B4513" Margin="0,0,0,10" CornerRadius="1"/>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">

                        <StackPanel x:Name="pnlMatchHistory">

                            <Border BorderBrush="#8B4513" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="ID: 1045" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Left"/>
                                        <TextBlock Text="05/06/2026" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Text="Rival: Vaquero_123" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                    <TextBlock Text="Palabra: ELEFANTE" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                    <TextBlock Text="GANADA: +10 pts" FontFamily="Courier New" FontWeight="Bold" FontSize="16" Foreground="#2E7D32" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="#8B4513" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="ID: 1042" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Left"/>
                                        <TextBlock Text="04/06/2026" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Text="Rival: Billy_The_Kid" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                    <TextBlock Text="Palabra: ESTERNOCLEIDO" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                    <TextBlock Text="PERDIDA: +0 pts" FontFamily="Courier New" FontWeight="Bold" FontSize="16" Foreground="#C62828" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="#8B4513" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="ID: 1038" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Left"/>
                                        <TextBlock Text="01/06/2026" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock Text="Rival: Sheriff_Woody" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                    <TextBlock Text="Palabra: CABALLO" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                    <TextBlock Text="PERDIDA POR ABANDONO: -3 pts" FontFamily="Courier New" FontWeight="Bold" FontSize="16" Foreground="#C62828" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,40">

            <Button x:Name="btnLanguage" 
                    Style="{StaticResource btnSquare}" Margin="0,0,20,0" 
                    ToolTip="{x:Static p:Resources.ttChangeLanguaje}" Click="btnLanguage_Click">

                <Image Source="/Properties/Images/languaje.png" Width="30" Height="30" Stretch="Uniform"/>

            </Button>

            <Popup x:Name="popLanguage" 
                   PlacementTarget="{Binding ElementName=btnLanguage}" 
                   Placement="Top" 
                   StaysOpen="False" 
                   AllowsTransparency="True" 
                   PopupAnimation="Slide">

                <Border Style="{StaticResource bdrSquareText}" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <Button x:Name="btnSpanish" Content="{x:Static p:Resources.lbLanguajeSpanish}" Style="{StaticResource btnMain}" 
                                Width="150" Height="40" Margin="0,0,0,10" Click="btnSpanish_Click"/>

                        <Button x:Name="btnEnglish" Content="{x:Static p:Resources.lbLanguajeEnglish}" Style="{StaticResource btnMain}" 
                                Width="150" Height="40" Click="btnEnglish_Click"/>
                    </StackPanel>
                </Border>
            </Popup>

            <Button x:Name="btnEditProfile" 
                    Style="{StaticResource btnSquare}" 
                    ToolTip="Mi Perfil" Click="btnEditProfile_Click">
                <Image Source="/Properties/Images/editProfile.png" Width="30" Height="30" Stretch="Uniform"/>
            </Button>


            <Popup x:Name="popEditProfile" 
                   PlacementTarget="{Binding ElementName=btnEditProfile}" 
                   Placement="Top" 
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">

                <Border Style="{StaticResource bdrCuadroTexto}" Width="400" Padding="25">
                    <StackPanel>
                        <Label Content="MI PERFIL" Style="{StaticResource lblTitulo}" FontSize="32" Margin="0,0,0,20"/>

                        <Label Content="NOMBRE" Style="{StaticResource lblSubtitulo}" FontSize="14"/>
                        <TextBox x:Name="txtProfName" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="165"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="APELLIDO PATERNO" Style="{StaticResource lblSubtitulo}" FontSize="14"/>
                                <TextBox x:Name="txtProfPaternalSurname" Style="{StaticResource txtNormal}" Width="165" Height="35" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="APELLIDO MATERNO" Style="{StaticResource lblSubtitulo}" FontSize="14"/>
                                <TextBox x:Name="txtProfMaternalSurname" Style="{StaticResource txtNormal}" Width="165" Height="35" FontSize="16"/>
                            </StackPanel>
                        </Grid>

                        <Label Content="NOMBRE DE USUARIO" Style="{StaticResource lblSubtitulo}" FontSize="14"/>
                        <TextBox x:Name="txtProfUsername" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,15"/>

                        <Label Content="CELULAR" Style="{StaticResource lblSubtitulo}" FontSize="14"/>
                        <TextBox x:Name="txtProfPhone" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,15"/>

                        <Label Content="CORREO ELECTRÓNICO" Style="{StaticResource lblSubtitulo}" FontSize="14"/>
                        <TextBox x:Name="txtProfEmail" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,30" 
                 IsReadOnly="True" Background="#E0E0E0" Foreground="Gray"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="btnSaveProfile" Content="GUARDAR" Click="btnSaveProfile_Click"
                    Style="{StaticResource btnMain}" 
                    Width="150" Height="45" Margin="0,0,20,0" FontSize="16"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </StackPanel>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40">
            <Button x:Name="btnCreateMatch" Content="NUEVA PARTIDA" 
                    Style="{StaticResource btnMain}" 
                    Width="280" Height="65" Margin="0,0,0,20" Click="btnCreateMatch_Click" Cursor=""/>

            <Button x:Name="btnPlay" Content="UNIRSE A PARTIDA" 
                    Style="{StaticResource btnMain}" 
                    Width="280" Height="65" Click="btnPlay_Click"/>
        </StackPanel>

    </Grid>
</Window>
