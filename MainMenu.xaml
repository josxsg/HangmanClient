<Window x:Class="HangmanClient.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/Properties/Images/Menu.png" Grid.ColumnSpan="2" Stretch="UniformToFill" Opacity="0.5"/>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">

            <StackPanel Orientation="Horizontal">
                <Label Content="{x:Static p:Resources.lbWelcome}" Style="{StaticResource lblSubtitle}" FontSize="24" VerticalAlignment="Center"/>
                <Label x:Name="lbUsername" Content="" Style="{StaticResource lblSubtitle}" FontSize="24" Foreground="Maroon" VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="btnLogout" 
                    Style="{StaticResource btnSquare}" 
                    Margin="0,10,0,0" HorizontalAlignment="Left"
                    ToolTip="{x:Static p:Resources.ttLogOut}"
                    Click="btnLogout_Click" Cursor="Hand">
                <Image Source="/Properties/Images/logOut.png" Width="30" Height="30" Stretch="Uniform"/>
            </Button>

        </StackPanel>

        <Button x:Name="btnMyPoints" 
                Style="{StaticResource btnSquare}" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,40,0"
                ToolTip="{x:Static p:Resources.ttMyPoints}" Click="btnMyPoints_Click">
            <Image Source="/Properties/Images/myPoints.png" Width="30" Height="30" Stretch="Uniform"/>
        </Button>

        <Popup x:Name="popMyPoints" PlacementTarget="{Binding ElementName=btnMyPoints}" 
               Placement="Left" 
               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">

            <Border Style="{StaticResource bdrSquareText}" Width="400" MaxHeight="500" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="{x:Static p:Resources.ttMyPoints}" Style="{StaticResource lblTitle}" FontSize="28" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="{x:Static p:Resources.lbMatches}" Style="{StaticResource lblSubtitle}" FontSize="18" HorizontalAlignment="Left"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Label Content="{x:Static p:Resources.lbTotal}" Style="{StaticResource lblSubtitle}" FontSize="18"/>
                            <Label x:Name="lblTotalPoints" Content="0 pts" Style="{StaticResource lblSubtitle}" FontSize="18" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" Height="3" Background="#8B4513" Margin="0,0,0,10" CornerRadius="1"/>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <ItemsControl x:Name="icMatchHistory">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#8B4513" BorderThickness="0,0,0,1" Padding="0,10">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding MatchIdText}" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Left"/>
                                                <TextBlock Text="{Binding DateText}" Style="{StaticResource txtBlock}" FontSize="14" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="{Binding RivalText}" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding WordText}" Style="{StaticResource txtBlock}" FontSize="16" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding ResultText}" FontFamily="Courier New" FontWeight="Bold" FontSize="16" 
                                                       Foreground="{Binding ResultColor}" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,40">

            <Button x:Name="btnLanguage" 
                    Style="{StaticResource btnSquare}" Margin="0,0,20,0" 
                    ToolTip="{x:Static p:Resources.ttChangeLanguaje}" Click="btnLanguage_Click">
                <Image Source="/Properties/Images/languaje.png" Width="30" Height="30" Stretch="Uniform"/>
            </Button>

            <Popup x:Name="popLanguage" 
                    PlacementTarget="{Binding ElementName=btnLanguage}" 
                    Placement="Top" 
                    StaysOpen="False" 
                    AllowsTransparency="True" 
                    PopupAnimation="Slide">

                <Border Style="{StaticResource bdrSquareText}" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <Button x:Name="btnSpanish" Content="{x:Static p:Resources.lbLanguajeSpanish}" Style="{StaticResource btnMain}" 
                                Width="150" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,10" Click="btnSpanish_Click"/>

                        <Button x:Name="btnEnglish" Content="{x:Static p:Resources.lbLanguajeEnglish}" Style="{StaticResource btnMain}" 
                                Width="150" Height="45" VerticalContentAlignment="Center" Click="btnEnglish_Click"/>
                    </StackPanel>
                </Border>
            </Popup>

            <Button x:Name="btnEditProfile" 
                    Style="{StaticResource btnSquare}" 
                    ToolTip="{x:Static p:Resources.ttMyProfile}" Click="btnEditProfile_Click">
                <Image Source="/Properties/Images/editProfile.png" Width="30" Height="30" Stretch="Uniform"/>
            </Button>

            <Popup x:Name="popEditProfile" 
                    PlacementTarget="{Binding ElementName=btnEditProfile}" 
                    Placement="Top" 
                    StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">

                <Border Style="{StaticResource bdrSquareText}" Width="400" Padding="25">
                    <StackPanel>
                        <Label Content="{x:Static p:Resources.ttMyProfile}" Style="{StaticResource lblTitle}" FontSize="32" Margin="0,0,0,20"/>

                        <DockPanel Width="340">
                            <Label Content="{x:Static p:Resources.lbName}" Style="{StaticResource lblSubtitle}" FontSize="14" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="lbProfNameCounter" Text="0/25" Foreground="#8B4513" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </DockPanel>
                        <TextBox x:Name="txtProfName" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,15" MaxLength="25" TextChanged="txtProfName_TextChanged"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="165"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="165"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <DockPanel Width="165">
                                    <Label Content="{x:Static p:Resources.lbLastName}" Style="{StaticResource lblSubtitle}" FontSize="13" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="lbProfPaternalSurnameCounter" Text="0/25" Foreground="#8B4513" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </DockPanel>
                                <TextBox x:Name="txtProfPaternalSurname" Style="{StaticResource txtNormal}" Width="165" Height="35" FontSize="16" MaxLength="25" TextChanged="txtProfPaternalSurname_TextChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <DockPanel Width="165">
                                    <Label Content="{x:Static p:Resources.lbLastName_Mother_}" Style="{StaticResource lblSubtitle}" FontSize="13" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="lbProfMaternalSurnameCounter" Text="0/25" Foreground="#8B4513" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </DockPanel>
                                <TextBox x:Name="txtProfMaternalSurname" Style="{StaticResource txtNormal}" Width="165" Height="35" FontSize="16" MaxLength="25" TextChanged="txtProfMaternalSurname_TextChanged"/>
                            </StackPanel>
                        </Grid>

                        <DockPanel Width="340">
                            <Label Content="{x:Static p:Resources.lbUsername}" Style="{StaticResource lblSubtitle}" FontSize="14" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="lbProfUsernameCounter" Text="0/25" Foreground="#8B4513" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </DockPanel>
                        <TextBox x:Name="txtProfUsername" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,15" MaxLength="25" TextChanged="txtProfUsername_TextChanged"/>

                        <DockPanel Width="340">
                            <Label Content="{x:Static p:Resources.lbPhone}" Style="{StaticResource lblSubtitle}" FontSize="14" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="lbProfPhoneCounter" Text="0/10" Foreground="#8B4513" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </DockPanel>
                        <TextBox x:Name="txtProfPhone" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,15" MaxLength="10" TextChanged="txtProfPhone_TextChanged"/>

                        <Label Content="{x:Static p:Resources.lbEmail}" Style="{StaticResource lblSubtitle}" FontSize="14"/>
                        <TextBox x:Name="txtProfEmail" Style="{StaticResource txtNormal}" Width="340" Height="35" FontSize="16" Margin="0,0,0,30" 
                                 IsReadOnly="True" Background="#E0E0E0" Foreground="Gray"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="btnSaveProfile" Content="GUARDAR" Click="btnSaveProfile_Click"
                                    Style="{StaticResource btnMain}" 
                                    Width="150" Height="45" Margin="0,0,20,0" FontSize="16"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </StackPanel>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40">
            <Button x:Name="btnCreateMatch" Content="{x:Static p:Resources.btnNewMatch}" 
                    Style="{StaticResource btnMain}" 
                    Width="280" Height="65" Margin="0,0,0,20" Click="btnCreateMatch_Click" Cursor=""/>

            <Button x:Name="btnPlay" Content="{x:Static p:Resources.btnJoinMatch}" 
                    Style="{StaticResource btnMain}" 
                    Width="280" Height="65" Click="btnPlay_Click"/>
        </StackPanel>

    </Grid>
</Window>