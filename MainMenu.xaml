<Window x:Class="HangmanClient.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HangmanClient"
        mc:Ignorable="d"
        xmlns:p="clr-namespace:HangmanClient.Properties"
        WindowState="Maximized" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="/Properties/Images/Menu.png" Grid.ColumnSpan="2" Stretch="UniformToFill" Opacity="0.5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <Label Content="BIENVENIDO(A): " Style="{StaticResource lblSubtitulo}" FontSize="24"/>
            <Label x:Name="lbUsername" Content="username" Style="{StaticResource lblSubtitulo}" FontSize="24" Foreground="Maroon"/>
        </StackPanel>

        <Button x:Name="btnMyPoints" Content="" 
                Style="{StaticResource btnCuadrado}" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,40,0"
                ToolTip="Ver Perfil" Click="btnMyPoints_Click"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,40">
            <Button x:Name="btnLanguage" Content="" Style="{StaticResource btnCuadrado}" Margin="0,0,20,0" ToolTip="Ver Puntaje" Click="btnLanguage_Click"/>
            <Button x:Name="btnEditProfile" Content="" Style="{StaticResource btnCuadrado}" ToolTip="Configuración" Click="btnEditProfile_Click"/>
        </StackPanel>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,40">
            <Button x:Name="btnCreateMatch" Content="NUEVA PARTIDA" 
                    Style="{StaticResource btnMain}" 
                    Width="280" Height="65" Margin="0,0,0,20" Click="btnCreateMatch_Click"/>

            <Button x:Name="btnPlay" Content="UNIRSE A PARTIDA" 
                    Style="{StaticResource btnMain}" 
                    Width="280" Height="65" Click="btnPlay_Click"/>
        </StackPanel>

    </Grid>
</Window>
